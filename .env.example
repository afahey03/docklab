APP_ENV=development
PORT=8080
DATABASE_URL=host=localhost port=5432 user=postgres dbname=docklab sslmode=disable
JWT_SECRET=dev-secret-change-me
JWT_TTL_MINUTES=60
# Minutes of terminal inactivity before a running workspace container is automatically stopped (default 60)
IDLE_STOP_AFTER_MINUTES=60
# Minutes of inactivity before a provisioned EC2 instance is stopped (default: 2x IDLE_STOP_AFTER_MINUTES)
IDLE_CLOUD_STOP_AFTER_MINUTES=
# Minutes of inactivity before a stopped EC2 instance is terminated via Terraform (default 1440 / 24h; set 0 to disable)
IDLE_CLOUD_TERMINATE_AFTER_MINUTES=1440
# Enable automatic EC2 stop/terminate for idle cloud environments (default true)
DOKLAB_CLOUD_IDLE_POLICY_ENABLED=true
# Static AWS keys are optional: the backend uses the default AWS credential chain,
# so an EC2 instance profile / ECS task role works with all three left blank.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
DOKLAB_TERRAFORM_STATE_BUCKET=
DOKLAB_TERRAFORM_STATE_REGION=us-east-1
DOKLAB_TERRAFORM_STATE_TABLE=
DOKLAB_TERRAFORM_STATE_KEY_PREFIX=docklab/environments
# SSH access to provisioned EC2 instances (required for remote workspaces after provisioning)
# In Docker Compose, the private key file on your machine (use ./ prefix for relative paths):
DOKLAB_SSH_PRIVATE_KEY_HOST_PATH=./keys/docklab-key.pem
# Path inside the backend container (matches docker-compose mount):
DOKLAB_SSH_PRIVATE_KEY_PATH=/run/secrets/docklab-ssh-key.pem
# Alternative to the mounted file: the key base64-encoded (e.g. delivered via
# Secrets Manager). Takes precedence over DOKLAB_SSH_PRIVATE_KEY_PATH when set.
DOKLAB_SSH_PRIVATE_KEY_B64=
DOKLAB_SSH_USER=ec2-user
DOKLAB_SSH_PORT=22
DOKLAB_SSH_CONNECT_TIMEOUT_SECONDS=15
DOKLAB_REMOTE_BOOTSTRAP_TIMEOUT_SECONDS=300

# --- Auth & sessions ---
# Days a refresh token stays valid (default 30)
REFRESH_TOKEN_TTL_DAYS=30
# GitHub OAuth app credentials (leave blank to disable "Continue with GitHub")
DOKLAB_GITHUB_CLIENT_ID=
DOKLAB_GITHUB_CLIENT_SECRET=
# Must match the OAuth app callback, e.g. http://localhost:8080/api/v1/auth/github/callback
DOKLAB_GITHUB_REDIRECT_URL=
# Where the backend redirects after OAuth and which origin CORS allows
DOKLAB_FRONTEND_BASE_URL=http://localhost:5173

# --- Production hardening ---
# Per-IP token bucket rate limits (per minute)
DOKLAB_RATE_LIMIT_ENABLED=true
DOKLAB_AUTH_RATE_LIMIT_PER_MINUTE=20
DOKLAB_PROVISION_RATE_LIMIT_PER_MINUTE=10
DOKLAB_API_RATE_LIMIT_PER_MINUTE=240
# Per-user resource quotas
DOKLAB_MAX_ENVIRONMENTS_PER_USER=10
DOKLAB_MAX_CONCURRENT_OPERATIONS_PER_USER=3
# Prometheus /metrics endpoint
DOKLAB_METRICS_ENABLED=true
# POST JSON alerts (provision failures, budget overruns, reconciliation events) to this URL
DOKLAB_ALERT_WEBHOOK_URL=
# Hydrate env vars from an AWS Secrets Manager JSON secret at boot (optional)
DOKLAB_SECRETS_MANAGER_SECRET_ID=
DOKLAB_SECRETS_MANAGER_REGION=

# --- Cost tracking ---
# Use the AWS Pricing API for hourly rates (falls back to a static table)
DOKLAB_PRICING_API_ENABLED=true

# --- Runtime backend ---
# "docker" (default) or "kubernetes" (requires kubectl + a configured context)
DOKLAB_RUNTIME=docker
DOKLAB_K8S_NAMESPACE=docklab
DOKLAB_K8S_CONTEXT=

# --- Browser IDE (code-server sidecar) ---
DOKLAB_IDE_ENABLED=true
DOKLAB_IDE_IMAGE=codercom/code-server:latest
# Public port used for the IDE on remote EC2 workspaces (matches the Terraform SG rule)
DOKLAB_IDE_REMOTE_PORT=8443